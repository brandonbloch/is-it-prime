{
	"name": "is-it-prime",
	"description": "Ever look at a number and wonder if it's prime?",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"author": {
		"name": "Brandon Bloch",
		"url": "https://bloch.ca",
		"email": "brandon@bloch.ca"
	},
	"homepage": "https://bloch.ca/is-it-prime",
	"repository": {
		"type": "git",
		"url": "https://github.com/brandonbloch/is-it-prime.git"
	},
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"lint": "bunx --bun @biomejs/biome check",
		"lint:fix": "bunx --bun @biomejs/biome check --write --unsafe",
		"build": "bun build ./src/index.html ./src/worker.ts --entry-naming='[name].[ext]' --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/index.ts"
	},
	"dependencies": {
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
